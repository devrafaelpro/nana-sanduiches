# ── Login do painel /admin ─────────────────────────────────
# Defina por cliente. Se não definir, usa admin / admin123.
ADMIN_USER=admin
ADMIN_PASS=admin123

# ── Identificador do cliente ───────────────────────────────
# Separa o cardápio de cada restaurante dentro do MESMO banco Redis.
# Use um valor único por cliente (ex: burguer-house, lanches-do-joao).
CLIENT_ID=default

# ── Upstash Redis (persistência do cardápio em produção) ───
# Um único banco grátis atende vários clientes. Sem estas variáveis,
# o app usa o arquivo data/menu.json (ótimo para rodar localmente).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternativa (nomes da Upstash direta) — o código aceita os dois:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Modo demonstração (APENAS no deploy de demo do vendedor) ─
# Liga o botão "Quero um site assim", mostra as credenciais na tela de login
# e faz as edições do admin expirarem sozinhas (auto-reset da demo).
# NUNCA defina nos projetos dos clientes.
# NEXT_PUBLIC_DEMO_MODE=1
# NEXT_PUBLIC_DEMO_WHATSAPP=5511999999999
# DEMO_RESET_SECONDS=3600
